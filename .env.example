# ── Exemple de configuration — copie ce fichier en .env.local et remplis les valeurs ──

# Email qui reçoit les demandes de rendez-vous
RDV_TO_EMAIL=ton@email.com

# Clé API Resend (https://resend.com → API Keys). Format: re_xxxxxxxx
RESEND_API_KEY=

# Domaine public du site (sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL=https://dentalida.dz

# ── BACKEND / DASHBOARD ──
# Base Postgres (Neon / Supabase) — connection string
DATABASE_URL=

# Secret de signature des sessions (génère: openssl rand -hex 32)
JWT_SECRET=

# Secret one-time pour /api/seed?secret=...
SEED_SECRET=

# Comptes initiaux
ADMIN_EMAIL=admin@exemple.com
ADMIN_PASSWORD=change-moi
MANAGER1_EMAIL=manager1@exemple.com
MANAGER1_PASSWORD=change-moi
MANAGER2_EMAIL=manager2@exemple.com
MANAGER2_PASSWORD=change-moi
